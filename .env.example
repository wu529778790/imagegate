# NextAuth Configuration (v5)
# Auth.js v5 prefers AUTH_URL, but NEXTAUTH_URL is still supported for backwards compatibility.
# Must be the exact URL users access (no trailing slash).
AUTH_URL=https://imagegate.shenzjd.com
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
